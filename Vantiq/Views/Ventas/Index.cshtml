@model List<Venta>
@{
    ViewData["Title"] = "Ventas";
    var conteos = (Dictionary<byte, int>)ViewBag.Conteos;
    byte? filtro = ViewBag.Estado;

    var estadosFiltro = new Dictionary<byte, string>
    {
        { 1, "Pendiente" },
        { 2, "Pagado"    },
        { 3, "Enviado"   },
        { 4, "Entregado" },
        { 5, "Cancelado" }
    };
}

<div class="container-fluid py-4">
    <div class="row g-4 admin-shell">
        <div class="col-lg-2 d-none d-lg-block"><partial name="_AdminSidebar" /></div>

        <div class="col-lg-10">
            <h1 class="font-display mb-1"><i class="bi bi-receipt text-gold me-2" aria-hidden="true"></i>Gestión de ventas</h1>
            <p class="text-muted-vq small mb-4">Ciclo de vida: Pendiente → Pagado → Enviado → Entregado</p>

            @* Filtros por estado (pills) + buscador en tiempo real *@
            <div class="table-toolbar mb-3">
                <a class="estado-pill @(filtro == null ? "estado-pagado" : "")" asp-action="Index"
                   style="text-decoration:none;">Todas (@conteos.Values.Sum())</a>

                @foreach (var estado in estadosFiltro)
                {
                    var total  = conteos.TryGetValue(estado.Key, out var n) ? n : 0;
                    var activo = estado.Key == filtro;
                    <a class="estado-pill estado-@(estado.Value.ToLower())" asp-action="Index"
                       asp-route-estado="@estado.Key"
                       style="text-decoration:none; @(activo ? "" : "opacity:.55;")">
                        @estado.Value (@total)
                    </a>
                }
                <div class="ms-auto"><partial name="_BuscadorTabla" model="@("tablaVentas")" /></div>
            </div>

            @if (Model.Count == 0)
            {
                <div class="card"><div class="card-body text-center text-muted-vq py-5">Sin ventas para este filtro.</div></div>
            }
            else
            {
                <div class="card">
                    <div class="table-responsive">
                        <table class="table table-vq table-hover mb-0" id="tablaVentas">
                            <thead>
                                <tr><th>N°</th><th>Fecha</th><th>Cliente</th><th>Tipo</th><th>Total</th><th>Estado</th><th></th></tr>
                            </thead>
                            <tbody>
                                @foreach (var venta in Model)
                                {
                                    <tr>
                                        <td class="font-monospace small fw-semibold text-gold">@Formato.CodigoVenta(venta.IdVenta)</td>
                                        <td class="small text-muted-vq">@venta.FechaHoraVenta.ToString("dd/MM/yyyy HH:mm")</td>
                                        <td>@venta.ClienteVisitante.NombresCliVisit @venta.ClienteVisitante.ApellidosCliVisit</td>
                                        <td>
                                            @if (venta.IdUsuario.HasValue)
                                            {
                                                <span class="badge-vq badge-gold">Con cuenta</span>
                                            }
                                            else
                                            {
                                                <span class="badge-vq" style="background:var(--vq-secondary); color:var(--vq-muted);">Invitado</span>
                                            }
                                        </td>
                                        <td>@Formato.Soles(venta.MontoTotal)</td>
                                        <td>
                                            <span class="estado-pill estado-@(venta.EstadoVenta.ToString().ToLower())">
                                                @venta.EstadoVenta
                                            </span>
                                        </td>
                                        <td>
                                            <a class="btn btn-outline-gold btn-sm" asp-action="Detalle" asp-route-id="@venta.IdVenta">
                                                Gestionar
                                            </a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_FiltroTablaScript" />
}
