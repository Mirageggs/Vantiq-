@model List<Venta>
@{
    ViewData["Title"] = "Mis compras";
}

<div class="container py-4">
    <h1 class="font-display mb-4"><i class="bi bi-bag-check text-gold me-2" aria-hidden="true"></i>Mis compras</h1>

    @if (Model.Count == 0)
    {
        <div class="text-center py-5 text-muted-vq">
            <i class="bi bi-bag d-block mb-3" style="font-size:3rem; opacity:.3;" aria-hidden="true"></i>
            <p>Aún no tienes compras registradas con tu cuenta.</p>
            <a class="btn btn-gold" asp-controller="Catalogo" asp-action="Index">Ir al catálogo</a>
        </div>
    }
    else
    {
        <div class="row g-3">
            @foreach (var venta in Model)
            {
                <div class="col-12">
                    <div class="card">
                        <div class="card-body">
                            <div class="d-flex flex-wrap align-items-center gap-3 mb-2">
                                <span class="font-monospace fw-semibold text-gold">@Formato.CodigoVenta(venta.IdVenta)</span>
                                <span class="small text-muted-vq">@venta.FechaHoraVenta.ToString("dd/MM/yyyy")</span>
                                <span class="estado-pill estado-@(venta.EstadoVenta.ToString().ToLower())">
                                    @venta.EstadoVenta
                                </span>
                                <span class="ms-auto fw-bold precio">@Formato.Soles(venta.MontoTotal)</span>
                            </div>
                            <div class="small">
                                @foreach (var det in venta.Detalles)
                                {
                                    <div class="d-flex justify-content-between border-top border-vq py-1">
                                        <span class="text-muted-vq">@det.Cantidad × @det.Reloj.CodigoSKU</span>
                                        <span>@Formato.Soles(det.PrecioUnitarioVenta * det.Cantidad)</span>
                                    </div>
                                }
                                @if (venta.MetodoPago != null)
                                {
                                    <div class="text-muted-vq mt-2">
                                        <i class="bi bi-credit-card me-1" aria-hidden="true"></i>@venta.MetodoPago.NombreMetodoPago
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
