@model DashboardViewModel
@{ ViewData["Title"] = "Dashboard"; }

<div class="container-fluid py-4">
    <div class="row g-4 admin-shell">
        @* Barra lateral reutilizable — visible en ≥ lg *@
        <div class="col-lg-2 d-none d-lg-block">
            <partial name="_AdminSidebar" />
        </div>

        <div class="col-lg-10">
            <div class="mb-4">
                <h1 class="font-display mb-1">Dashboard</h1>
                <p class="text-muted-vq small mb-0">Resumen general · @DateTime.Now.ToString("dddd, d 'de' MMMM 'de' yyyy", new System.Globalization.CultureInfo("es-PE"))</p>
            </div>

            @* ══ KPIs (Data Cards del Figma) ══ *@
            <div class="row row-cols-2 row-cols-lg-4 g-3 mb-4">
                <div class="col">
                    <div class="kpi-card p-3 p-lg-4 h-100">
                        <div class="d-flex justify-content-between align-items-start mb-3">
                            <span class="kpi-label">Ventas del mes</span>
                            <span class="kpi-ico green"><i class="bi bi-graph-up-arrow" aria-hidden="true"></i></span>
                        </div>
                        <p class="kpi-value font-display mb-1">@Formato.Soles(Model.VentasDelMes)</p>
                        <p class="small text-muted-vq mb-0">Pedidos no cancelados</p>
                    </div>
                </div>
                <div class="col">
                    <div class="kpi-card p-3 p-lg-4 h-100">
                        <div class="d-flex justify-content-between align-items-start mb-3">
                            <span class="kpi-label">Pedidos pendientes</span>
                            <span class="kpi-ico blue"><i class="bi bi-hourglass-split" aria-hidden="true"></i></span>
                        </div>
                        <p class="kpi-value font-display mb-1">@Model.VentasPendientes</p>
                        <a class="small" asp-controller="Ventas" asp-action="Index" asp-route-estado="1">Gestionar →</a>
                    </div>
                </div>
                <div class="col">
                    <div class="kpi-card p-3 p-lg-4 h-100">
                        <div class="d-flex justify-content-between align-items-start mb-3">
                            <span class="kpi-label">Stock crítico</span>
                            <span class="kpi-ico yellow"><i class="bi bi-exclamation-triangle" aria-hidden="true"></i></span>
                        </div>
                        <p class="kpi-value font-display mb-1 @(Model.StockCritico.Count > 0 ? "text-warning" : "")">@Model.StockCritico.Count</p>
                        <p class="small text-muted-vq mb-0">Relojes con ≤ 3 unidades</p>
                    </div>
                </div>
                <div class="col">
                    <div class="kpi-card p-3 p-lg-4 h-100">
                        <div class="d-flex justify-content-between align-items-start mb-3">
                            <span class="kpi-label">Clientes</span>
                            <span class="kpi-ico purple"><i class="bi bi-people" aria-hidden="true"></i></span>
                        </div>
                        <p class="kpi-value font-display mb-1">@Model.ClientesRegistrados</p>
                        <p class="small text-muted-vq mb-0">Cuentas registradas</p>
                    </div>
                </div>
            </div>

            @* ══ Gráficos (Chart.js) ══ *@
            <div class="row g-3 mb-4">
                <div class="col-lg-8">
                    <div class="card h-100">
                        <div class="card-body">
                            <h2 class="h6 font-display mb-4">Ventas de los últimos 30 días</h2>
                            <canvas id="graficoVentas" height="110" aria-label="Gráfico de ventas por día" role="img"></canvas>
                        </div>
                    </div>
                </div>
                <div class="col-lg-4">
                    <div class="card h-100">
                        <div class="card-body">
                            <h2 class="h6 font-display mb-4">Top 5 más vendidos</h2>
                            @if (Model.TopRelojes.Count == 0)
                            {
                                <p class="small text-muted-vq">Aún no hay ventas registradas.</p>
                            }
                            <canvas id="graficoTop" height="220" aria-label="Relojes más vendidos" role="img"></canvas>
                        </div>
                    </div>
                </div>
            </div>

            @* ══ Alertas de stock ══ *@
            <div class="card">
                <div class="card-body">
                    <h2 class="h6 font-display mb-3">
                        <i class="bi bi-exclamation-triangle text-warning me-1" aria-hidden="true"></i>Alertas de stock
                    </h2>
                    @if (Model.StockCritico.Count == 0)
                    {
                        <p class="small text-muted-vq mb-0">Todo el catálogo tiene stock saludable.</p>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-vq table-hover mb-0">
                                <thead>
                                    <tr><th>SKU</th><th>Modelo / Marca</th><th>Stock</th><th></th></tr>
                                </thead>
                                <tbody>
                                    @foreach (var reloj in Model.StockCritico)
                                    {
                                        <tr>
                                            <td class="small font-monospace">@reloj.CodigoSKU</td>
                                            <td>@reloj.ModeloReloj.NombreModelo <span class="text-muted-vq small">/ @reloj.Marca.NombreMarca</span></td>
                                            <td><span class="@(reloj.StockActual == 0 ? "stock-cero" : "stock-bajo") fw-bold">@reloj.StockActual</span></td>
                                            <td>
                                                <a class="btn btn-outline-gold btn-sm" asp-controller="Inventario"
                                                   asp-action="Kardex" asp-route-id="@reloj.IdReloj">Reponer</a>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.3/dist/chart.umd.min.js"></script>
<script>
    const serieVentas = @Html.Raw(Json.Serialize(Model.VentasPorDia));
    const topRelojes  = @Html.Raw(Json.Serialize(Model.TopRelojes));

    // Tokens de color del tema (coinciden con el Figma)
    const GOLD = "#C8A96E", MUTED = "#7A7570", BORDER = "rgba(200,169,110,0.15)";
    Chart.defaults.color = MUTED;
    Chart.defaults.borderColor = "rgba(43,39,33,0.6)";
    Chart.defaults.font.family = "Inter, sans-serif";

    new Chart(document.getElementById("graficoVentas"), {
        type: "line",
        data: {
            labels: serieVentas.map(p => p.etiqueta),
            datasets: [{
                label: "Ventas (S/)",
                data: serieVentas.map(p => p.valor),
                borderColor: GOLD,
                backgroundColor: "rgba(200,169,110,0.12)",
                fill: true, tension: 0.35, pointRadius: 2, pointHoverRadius: 5
            }]
        },
        options: {
            plugins: { legend: { display: false } },
            scales: { y: { beginAtZero: true }, x: { ticks: { maxTicksLimit: 10 } } }
        }
    });

    new Chart(document.getElementById("graficoTop"), {
        type: "doughnut",
        data: {
            labels: topRelojes.map(p => p.etiqueta),
            datasets: [{
                data: topRelojes.map(p => p.valor),
                backgroundColor: [GOLD, "#a8894f", "#7A7570", "#d8bf8f", "#4a4238"],
                borderColor: "#1A1815", borderWidth: 2
            }]
        },
        options: { plugins: { legend: { position: "bottom", labels: { boxWidth: 12, padding: 12 } } } }
    });
</script>
}
