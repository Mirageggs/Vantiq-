@model Reloj
@{
    ViewData["Title"] = "Editar " + Model.CodigoSKU;
    var estados = (List<EstadoReloj>)ViewBag.Estados;
}

<div class="container-fluid py-4">
    <div class="row g-4 admin-shell">
        <div class="col-lg-2 d-none d-lg-block"><partial name="_AdminSidebar" /></div>

        <div class="col-lg-10">
            <h1 class="font-display mb-4"><i class="bi bi-pencil-square text-gold me-2" aria-hidden="true"></i>Editar <span class="text-gold font-monospace">@Model.CodigoSKU</span></h1>

            <div class="card">
                <div class="card-body p-4">
                    <p class="small text-muted-vq mb-3">
                        Modelo: <strong>@Model.ModeloReloj.NombreModelo</strong> · Marca: <strong>@Model.Marca.NombreMarca</strong>
                        · Stock actual: <strong>@Model.StockActual</strong>
                        (el stock solo cambia desde el <a asp-action="Kardex" asp-route-id="@Model.IdReloj">Kárdex</a>)
                    </p>
                    <form asp-action="Editar" method="post" class="row g-3">
                        <input type="hidden" name="id" value="@Model.IdReloj" />
                        <div class="col-md-3">
                            <label class="eyebrow d-block mb-1">Precio (S/)</label>
                            <input type="number" name="precio" class="form-control" min="0.01" step="0.01"
                                   value="@Model.Precio.ToString(System.Globalization.CultureInfo.InvariantCulture)" required />
                        </div>
                        <div class="col-md-3">
                            <label class="eyebrow d-block mb-1">Estado</label>
                            <select name="idEstadoReloj" class="form-select">
                                @foreach (var estado in estados)
                                {
                                    <option value="@estado.IdEstadoReloj" selected="@(estado.IdEstadoReloj == Model.IdEstadoReloj)">@estado.NombreEstadoReloj</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="eyebrow d-block mb-1">URL de la imagen</label>
                            <input type="text" name="urlImagen" class="form-control" value="@Model.UrlImagen" required />
                        </div>
                        <div class="col-12">
                            <label class="eyebrow d-block mb-1">Descripción</label>
                            <textarea name="descripcion" class="form-control" rows="2">@Model.Descripcion</textarea>
                        </div>
                        <div class="col-12 d-flex gap-2">
                            <button type="submit" class="btn btn-gold"><i class="bi bi-save me-1" aria-hidden="true"></i>Actualizar</button>
                            <a class="btn btn-outline-gold" asp-action="Index">Cancelar</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
